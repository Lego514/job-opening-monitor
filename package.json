{
  "name": "job-opening-monitor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Scheduled monitor that detects new matching job postings (Workday/iCIMS), alerts via Telegram + email, and auto-adds them to the job tracker.",
  "scripts": {
    "start": "tsx src/index.ts",
    "seed": "node --env-file=.env --import tsx src/index.ts --seed",
    "run:live": "node --env-file=.env --import tsx src/index.ts",
    "dry-run": "tsx src/index.ts --dry-run",
    "check": "tsx scripts/check-sources.ts",
    "keywords": "tsx scripts/keywords.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
