# Copy to .env and fill in (or set these as GitHub repo secrets for the scheduled run).
# Run locally with:  node --env-file=.env  (or `npm start` after exporting them).
# Everything except the Supabase + tracker vars is optional — unset channels are skipped.

# Supabase (same project as the tracker). SERVICE ROLE key — server-only, NEVER commit/expose.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Your tracker account's user id (Supabase dashboard -> Authentication -> Users -> copy the UUID).
TRACKER_USER_ID=

# Telegram (fast alerts): create a bot via @BotFather, then get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email alerts via Resend (https://resend.com). Optional.
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=onboarding@resend.dev

# --- Optional behavior tuning ---
# Don't alert/add roles whose JD rules out F-1 sponsorship (still recorded as seen):
# SKIP_NO_SPONSORSHIP=true
# Only alert roles posted within N days (reduces stale-repost noise):
# MAX_AGE_DAYS=14
